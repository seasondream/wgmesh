#!/usr/bin/env bash
# Optional pre-commit hook: scan staged files in company/ for secrets.
# Install: cp .github/hooks/pre-commit-secret-scan .git/hooks/pre-commit
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Only scan company/ files
staged_company_files=$(git diff --cached --name-only -- 'company/' 2>/dev/null || true)

if [ -z "$staged_company_files" ]; then
  exit 0
fi

echo "Scanning company/ files for secrets..."

for file in $staged_company_files; do
  if [ -f "$file" ]; then
    cat "$file" | bash "$REPO_ROOT/company/scripts/sanitise.sh" > /dev/null
    if [ $? -ne 0 ]; then
      echo "BLOCKED: Secret detected in $file"
      exit 1
    fi
  fi
done

echo "Secret scan passed."
